POSTGRES_DB=hospital_sim
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
BACKEND_PORT=4000
FRONTEND_PORT=5173
CONTROL_PANEL_PORT=5180
DEFAULT_ADMIN_ENABLED=true
DEFAULT_ADMIN_EMAIL=admin@hospital.local
DEFAULT_ADMIN_PASSWORD=dyantrace
DEFAULT_ADMIN_NAME=Administrador Padrao
DEFAULT_ADMIN_DEPARTMENT=NOC Hospitalar
SIMULATION_CONTROL_KEY=troque-esta-chave-forte
SIMULATION_JOB_ENABLED=true
SIMULATION_JOB_MODE=interval
SIMULATION_JOB_INTERVAL_MINUTES=30
SIMULATION_JOB_CRON=*/30 * * * *
SIMULATION_JOB_TIMEZONE=America/Sao_Paulo
SIMULATION_JOB_PROFILE=light
SIMULATION_JOB_ROLES=patient,doctor,receptionist
SIMULATION_JOB_RUN_ON_START=true
SIMULATION_JOB_START_DELAY_SECONDS=20
SIMULATION_JOB_SESSIONS=40
SIMULATION_JOB_DURATION_SECONDS=300
SIMULATION_JOB_RAMP_UP_SECONDS=30
SIMULATION_JOB_REQUEST_PACING_MS=1200
SIMULATION_JOB_JITTER_MS=450
CONTROL_PANEL_USER=admin
CONTROL_PANEL_PASSWORD=dyantrace
CONTROL_PANEL_SESSION_SECRET=troque-esta-sessao
CONTROL_PANEL_SESSION_TTL_SECONDS=28800
RUM_BROWSER_VUS=5
RUM_BROWSER_DURATION=3m
K6_BROWSER_HEADLESS=true
K6_BROWSER_ARGS=no-sandbox

# Dynatrace OneAgent for Docker containers (profile: dynatrace)
# Script URL and token are generated in Dynatrace UI:
# Deploy Dynatrace > Start installation > Containerized environments > Docker
ONEAGENT_INSTALLER_SCRIPT_URL=
ONEAGENT_INSTALLER_DOWNLOAD_TOKEN=
ONEAGENT_INSTALLER_SKIP_CERT_CHECK=false
ONEAGENT_CONTAINER_READ_ONLY=true
ONEAGENT_HOST_ROOT_MOUNT_MODE=ro
ONEAGENT_ENABLE_VOLUME_STORAGE=true

# Fallback para Docker Desktop local (Windows/macOS):
# ONEAGENT_CONTAINER_READ_ONLY=false
# ONEAGENT_HOST_ROOT_MOUNT_MODE=rw
# ONEAGENT_ENABLE_VOLUME_STORAGE=false
